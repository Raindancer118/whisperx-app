# ── App ───────────────────────────────────────────────────────────────────
APP_URL=https://whisperx.yourdomain.com
PORT=80

# ── Volantic Auth (OAuth2 — public PKCE client, kein Secret nötig) ────────
VOLANTIC_CLIENT_ID=whisperx-app

# ── Session ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password

# ── SMTP (noreply@volantic.de via mx.volantic.de) ────────────────────────
SMTP_PASSWORD=your-smtp-password-here

# ── HuggingFace Token (für pyannote Sprecher-Diarisierung) ───────────────
# Erstelle einen Token auf: https://hf.co/settings/tokens
# Akzeptiere die Nutzungsbedingungen: https://hf.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_...
