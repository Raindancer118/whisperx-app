# ── App ───────────────────────────────────────────────────────────────────
APP_URL=https://whisperx.yourdomain.com

# Ports exposed to the host (NPM proxies to these)
API_PORT=8000        # FastAPI  — NPM → this_host:8000
FRONTEND_PORT=8080   # React SPA — NPM → this_host:8080

# Bind address for exposed ports.
# Leave empty (or 0.0.0.0) to accept connections from any interface.
# Set to 127.0.0.1 if NPM runs on the same host and you want to block
# direct external access to these ports.
BIND_ADDR=0.0.0.0

# ── Volantic Auth (OAuth2 — public PKCE client, kein Secret nötig) ────────
VOLANTIC_CLIENT_ID=whisperx-app

# ── Session ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password

# ── SMTP (noreply@volantic.de via mx.volantic.de) ────────────────────────
SMTP_PASSWORD=your-smtp-password-here

# ── HuggingFace Token (für pyannote Sprecher-Diarisierung) ───────────────
# Erstelle einen Token auf: https://hf.co/settings/tokens
# Akzeptiere die Nutzungsbedingungen: https://hf.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_...

# ── Crowd / Discord Live-Stream ───────────────────────────────────────────
# Geheimer API-Key für den /crowd WebSocket-Endpunkt.
# Generieren mit: python -c "import secrets; print(secrets.token_urlsafe(32))"
# PFLICHT in Production — ohne Key werden alle Verbindungen akzeptiert (nur Dev!)
CROWD_API_KEY=change-me-to-a-random-secret

# Lokales Ollama-Modell für Transkript-Korrektur und Zusammenfassung
# Verfügbare Tags (nach `ollama pull`):
#   gemma4:e2b   — schnell, ~2-3 GB RAM  (empfohlen bei 8 GB RAM)
#   gemma4:e4b   — besser,  ~4-5 GB RAM  (empfohlen bei 16 GB RAM)
OLLAMA_MODEL=gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=300

# Whisper-Modell für Rolling-Transkription (Rohtranskript während Stream)
# Kleine Modelle: tiny, base, small  — "base" ist ein guter Kompromiss
CROWD_LIVE_MODEL=base
# Intervall in Sekunden für Rolling-Transkription
CROWD_ROLLING_INTERVAL=30
