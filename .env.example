# WhisperX-App — Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.

# Volantic Auth Client-ID (muss in Volantic Auth registriert sein)
VOLANTIC_CLIENT_ID=whisperx-app

# Volantic Auth Issuer URL
VOLANTIC_ISSUER=https://accounts.volantic.de

# API Server (optional, kann auch per CLI-Flag gesetzt werden)
API_HOST=0.0.0.0
API_PORT=8000

# HuggingFace Token für Speaker Diarization
# Alternativ beim ersten Start eingeben — wird in ~/.whisperx/config.json gespeichert
# HF_TOKEN=hf_...
